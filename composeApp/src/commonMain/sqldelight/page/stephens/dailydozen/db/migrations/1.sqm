-- v1 -> v2: add the syncState table for existing installs (the count-based
-- servingLog table from v1 is left intact for the non-destructive migration).
-- Fresh installs create both tables from DailyDozen.sq and never run this file.
CREATE TABLE syncState (
    id              INTEGER NOT NULL PRIMARY KEY,
    blobJson        TEXT NOT NULL,
    syncedUpdatedAt TEXT,
    dirty           INTEGER NOT NULL DEFAULT 0
);
