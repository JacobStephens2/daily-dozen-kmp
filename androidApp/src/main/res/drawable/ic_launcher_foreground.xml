<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground: a single leaf (whole-food / plant motif) with a
  checkmark cut into it (the daily "logged" gesture). Drawn inside the 108x108
  viewport with all content kept within the centre safe zone so the launcher
  mask never clips it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Leaf body -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M54,24
            C40,33 33,47 33,59
            C33,73 43,83 54,84
            C65,83 75,73 75,59
            C75,47 68,33 54,24 Z" />

    <!-- Mid-rib and side veins, drawn in the background green so they read as
         cut into the white leaf. -->
    <path
        android:strokeColor="#FF2F5733"
        android:strokeWidth="2.4"
        android:strokeLineCap="round"
        android:pathData="M54,31 L54,52" />
    <path
        android:strokeColor="#FF2F5733"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:pathData="M54,45 L43,39 M54,53 L66,46" />

    <!-- Checkmark over the lower leaf -->
    <path
        android:strokeColor="#FF2F5733"
        android:strokeWidth="5.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M44,63 L51,70 L66,53" />
</vector>
